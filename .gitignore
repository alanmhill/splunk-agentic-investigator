# splunk runtime (VERY important)
# Never commit Splunk-generated secrets/state
splunk/local/server.conf
splunk/local/passwords.conf
splunk/local/*.old
splunk/local_BAD_*
!splunk/local/README.md

# Splunk local backup (contains generated/encrypted configs)
splunk/local_BAD_*